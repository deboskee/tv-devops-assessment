{
  "name": "express-ts-app",
  "version": "1.0.0",
  "description": "Express.js + TypeScript application with Docker and AWS deployment",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "test": "echo \"Tests would run here\" && exit 0"
  },
  "keywords": ["express", "typescript", "docker", "aws", "ecs"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^17.2.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.13",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
