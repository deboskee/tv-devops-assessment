{
  "name": "express-ts-app-iac",
  "version": "1.0.0",
  "description": "CDK for Terraform infrastructure for Express.js application",
  "main": "main.js",
  "scripts": {
    "get": "cdktf get",
    "build": "tsc",
    "synth": "cdktf synth",
    "compile": "tsc --pretty",
    "watch": "tsc -w",
    "test": "jest",
    "upgrade": "npm i cdktf@latest cdktf-cli@latest",
    "upgrade:next": "npm i cdktf@next cdktf-cli@next",
    "deploy": "cdktf deploy",
    "deploy:dev": "TF_VAR_environment=dev cdktf deploy",
    "deploy:staging": "TF_VAR_environment=staging cdktf deploy",
    "deploy:prod": "TF_VAR_environment=prod cdktf deploy",
    "destroy": "cdktf destroy",
    "diff": "cdktf diff",
    "output": "cdktf output"
  },
  "keywords": [
    "cdktf",
    "terraform",
    "aws",
    "ecs",
    "fargate"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@cdktf/provider-aws": "^19.0.0",
    "@cdktf/provider-random": "11.1.1",
    "cdktf": "^0.20.0",
    "constructs": "^10.3.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.10.0",
    "cdktf-cli": "^0.20.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
