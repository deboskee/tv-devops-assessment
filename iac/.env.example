# =============================================================================
# Infrastructure Configuration
# =============================================================================
# Copy this file to .env and customize for your environment
# Or create environment-specific files: .env.dev, .env.staging, .env.prod
# =============================================================================

# -----------------------------------------------------------------------------
# Required: AWS Configuration
# -----------------------------------------------------------------------------
TF_VAR_aws_region=us-east-1
TF_VAR_aws_account_id=123456789012

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
TF_VAR_app_name=express-ts-app
TF_VAR_environment=dev

# -----------------------------------------------------------------------------
# ECR Configuration
# -----------------------------------------------------------------------------
TF_VAR_ecr_repository_name=express-ts-app
TF_VAR_image_tag=latest

# -----------------------------------------------------------------------------
# ECS Configuration
# -----------------------------------------------------------------------------
TF_VAR_ecs_cpu=256
TF_VAR_ecs_memory=512
TF_VAR_desired_count=1
TF_VAR_min_count=1
TF_VAR_max_count=4

# -----------------------------------------------------------------------------
# VPC Configuration
# -----------------------------------------------------------------------------
TF_VAR_vpc_cidr=10.0.0.0/16
TF_VAR_max_azs=2

# -----------------------------------------------------------------------------
# Optional: Domain & HTTPS
# -----------------------------------------------------------------------------
# TF_VAR_domain_name=example.com
# TF_VAR_hosted_zone_id=Z1234567890ABC
# TF_VAR_enable_https=true

# -----------------------------------------------------------------------------
# Optional: Remote Backend (S3 + DynamoDB)
# -----------------------------------------------------------------------------
# Run scripts/bootstrap-backend.sh first to create these resources
# TF_VAR_backend_bucket=express-ts-app-tfstate-us-east-1
# TF_VAR_backend_dynamodb_table=express-ts-app-tfstate-lock

# -----------------------------------------------------------------------------
# Optional: Monitoring
# -----------------------------------------------------------------------------
TF_VAR_enable_cloudwatch=true
TF_VAR_log_retention_days=7
TF_VAR_enable_alarms=false
# TF_VAR_alarm_email=alerts@example.com
